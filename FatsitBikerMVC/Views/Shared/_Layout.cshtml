<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fatsit Biker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .footer-hover:hover { color: #ffc107 !important; padding-left: 5px; transition: 0.3s; }
        .footer-link { transition: 0.3s; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- 1. TOP BAR -->
    <div class="top-bar d-none d-lg-block">
        <div class="container d-flex justify-content-between">
            <div>
                <a href="#"><i class="fas fa-phone-alt"></i> Hotline: 1800.6610</a>
                <a href="#"><i class="fas fa-building"></i> FATSIT BIKER HOLDING</a>
            </div>
            <div>
                <a href="#" data-bs-toggle="modal" data-bs-target="#topPromoModal" class="text-warning fw-bold"><i class="fas fa-tags"></i> Khuyến mãi</a>
            </div>
        </div>
    </div>

    <!-- 2. HEADER / NAVBAR -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container align-items-center">
            <a class="navbar-brand me-4" asp-controller="Home" asp-action="Index">
                <i class="fab fa-honda"></i> FATSIT BIKER
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i class="fas fa-bars text-white fs-3"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto align-items-center">
                    <li class="nav-item me-3"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item dropdown me-3">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Sản phẩm
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" asp-controller="Product" asp-action="List" asp-route-categoryId="0">Tất cả xe</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" asp-controller="Product" asp-action="List" asp-route-categoryId="1">Xe Tay Ga</a></li>
                            <li><a class="dropdown-item" asp-controller="Product" asp-action="List" asp-route-categoryId="2">Xe Số</a></li>
                            <li><a class="dropdown-item" asp-controller="Product" asp-action="List" asp-route-categoryId="3">Xe Côn Tay</a></li>
                            <li><a class="dropdown-item" asp-controller="Product" asp-action="List" asp-route-categoryId="4">Xe Điện</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown me-3">
                        <a class="nav-link dropdown-toggle" href="#" id="servicesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Dịch vụ
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="servicesDropdown">
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="NanoCoating">Dịch vụ dán nano cho xe</a></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="LoanSupport">Dịch vụ hỗ trợ cho vay mua xe</a></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Maintenance">Dịch vụ bảo dưỡng xe tận nơi</a></li>
                        </ul>
                    </li>
                    <li class="nav-item me-3"><a class="nav-link" asp-controller="Home" asp-action="Stores">Cửa hàng</a></li>
                    <li class="nav-item dropdown me-3">
                        <a class="nav-link dropdown-toggle text-warning" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-cogs"></i> Quản trị
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="adminDropdown">
                            <li><a class="dropdown-item" asp-controller="CategoryManager" asp-action="Index"><i class="fas fa-list-alt me-2 text-info"></i> Quản lý danh mục</a></li>
                            <li><a class="dropdown-item" asp-controller="ProductManager" asp-action="Index"><i class="fas fa-motorcycle me-2 text-success"></i> Quản lý sản phẩm</a></li>
                        </ul>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <form asp-controller="Product" asp-action="List" method="get" class="input-group input-group-sm d-none d-md-flex" style="width: 200px;">
                        <input type="text" name="searchQuery" class="form-control bg-dark border-secondary text-white" placeholder="Tìm xe..." value="@Context.Request.Query["searchQuery"]">
                        <button class="btn btn-outline-secondary border-secondary" type="submit">
                            <i class="fas fa-search text-white"></i>
                        </button>
                    </form>
                    <a href="#" class="text-white fs-5 position-relative">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">0</span>
                    </a>
                    <a href="#" class="text-white fs-5"><i class="fas fa-user-circle"></i></a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid p-0">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="bg-dark text-white pt-5 pb-3 mt-5 border-top border-danger border-3">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="text-warning mb-3 fw-bold"><i class="fab fa-honda text-danger"></i> FATSIT BIKER</h5>
                    <p class="text-secondary small">Hệ thống Đại lý xe máy Chính hãng Fatsit Biker. Chúng tôi cam kết mang đến sản phẩm chính hãng, chất lượng và dịch vụ bảo hành tận tâm nhất.</p>
                    <div class="mt-3">
                        <i class="fas fa-map-marker-alt text-danger me-2"></i> <span class="text-secondary small">123 Đường Biker, Quận 1, TP. HCM</span><br>
                        <i class="fas fa-phone-alt text-danger me-2 mt-2"></i> <span class="text-secondary small">Hotline: 1800.6610</span><br>
                        <i class="fas fa-envelope text-danger me-2 mt-2"></i> <span class="text-secondary small">support@fatsitbiker.com</span>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 mb-4">
                    <h5 class="text-white mb-3 fw-bold">Sản Phẩm</h5>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="/Product/List?categoryId=1" class="text-secondary text-decoration-none footer-hover">Xe Tay Ga</a></li>
                        <li class="mb-2"><a href="/Product/List?categoryId=2" class="text-secondary text-decoration-none footer-hover">Xe Số</a></li>
                        <li class="mb-2"><a href="/Product/List?categoryId=3" class="text-secondary text-decoration-none footer-hover">Xe Côn Tay</a></li>
                        <li class="mb-2"><a href="/Product/List?categoryId=4" class="text-secondary text-decoration-none footer-hover">Xe Điện</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5 class="text-white mb-3 fw-bold">Dịch Vụ</h5>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="/Services/NanoCoating" class="text-secondary text-decoration-none footer-hover">Dán Nano Bảo Vệ</a></li>
                        <li class="mb-2"><a href="/Services/LoanSupport" class="text-secondary text-decoration-none footer-hover">Hỗ Trợ Trả Góp 0%</a></li>
                        <li class="mb-2"><a href="/Services/Maintenance" class="text-secondary text-decoration-none footer-hover">Bảo Dưỡng Lưu Động</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none footer-hover">Cứu Hộ 24/7</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4 text-md-start">
                    <h5 class="text-white mb-3 fw-bold">Kết Nối</h5>
                    <p class="text-secondary small mb-3">Theo dõi chúng tôi để cập nhật các dòng xe mới nhất và ưu đãi hấp dẫn.</p>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-white bg-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; text-decoration: none;"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="text-white bg-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; text-decoration: none;"><i class="fab fa-youtube"></i></a>
                        <a href="#" class="text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); text-decoration: none;"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
            <hr class="border-secondary mt-2 mb-3">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <span class="text-secondary small">&copy; 2026 Hệ thống Fatsit Biker. All rights reserved.</span>
                </div>
                <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
                    <i class="fab fa-cc-visa text-secondary fs-4 me-2"></i>
                    <i class="fab fa-cc-mastercard text-secondary fs-4"></i>
                </div>
            </div>
        </div>
    </footer>

    <!-- TOP PROMO MODAL -->
    <div class="modal fade" id="topPromoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content bg-dark border-danger" style="border-width: 2px;">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-warning fw-bold"><i class="fas fa-gift me-2 text-danger"></i> ƯU ĐÃI ĐẶC QUYỀN FATSIT BIKER</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="row g-0">
                        <div class="col-md-6 border-end border-secondary text-center">
                            <img src="~/images/left_promo_banner.png" class="img-fluid w-100" style="max-height: 500px; object-fit: contain; background: #000;" alt="Promo 1">
                        </div>
                        <div class="col-md-6 text-center">
                            <img src="~/images/right_promo_banner.png" class="img-fluid w-100" style="max-height: 500px; object-fit: contain; background: #000;" alt="Promo 2">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FLOAT CONTACT -->
    <div class="floating-contact">
        <a href="#" class="contact-item contact-zalo" title="Chat Zalo" style="background: #0084ff;">
            <i class="fas fa-comment"></i>
        </a>
        <a href="#" class="contact-item contact-messenger" title="Chat Facebook" style="background: #00c6ff;">
            <i class="fab fa-facebook-messenger"></i>
        </a>
        <a href="tel:18006610" class="contact-item contact-phone" title="Gọi ngay">
            <i class="fas fa-phone-alt"></i>
        </a>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
