@using Microsoft.AspNetCore.Identity
@using FatsitBikerMVC.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="d-flex align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var displayName = user?.FullName ?? UserManager.GetUserName(User);
    
    <div class="dropdown">
        <a class="btn btn-outline-warning dropdown-toggle d-flex align-items-center gap-2 px-3 py-2 rounded-pill shadow-sm" href="#" role="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="fas fa-user-circle fs-5"></i>
            <span class="d-none d-sm-inline fw-semibold small">@displayName</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow border-secondary mt-2" aria-labelledby="userMenuDropdown">
            <li>
                <div class="dropdown-header text-muted border-bottom border-secondary pb-2 mb-2">
                    <i class="fas fa-id-badge me-2 text-warning"></i> @UserManager.GetUserName(User)
                </div>
            </li>
            <li>
                <a class="dropdown-item py-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                    <i class="fas fa-user-cog me-2 text-info"></i> Thiết lập tài khoản
                </a>
            </li>
            <li><hr class="dropdown-divider border-secondary"></li>
            <li>
                <form id="logoutForm" class="d-inline w-100" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button id="logout" type="submit" class="dropdown-item py-2 text-danger fw-semibold">
                        <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
                    </button>
                </form>
            </li>
        </ul>
    </div>
}
else
{
    <a class="btn btn-sm btn-outline-light px-3 py-2 rounded-pill fw-semibold small hover-warning" id="login" asp-area="Identity" asp-page="/Account/Login">
        <i class="fas fa-sign-in-alt me-1"></i> Đăng nhập
    </a>
    <a class="btn btn-sm btn-warning px-3 py-2 rounded-pill fw-bold small shadow-sm text-dark hover-zoom" id="register" asp-area="Identity" asp-page="/Account/Register">
        <i class="fas fa-user-plus me-1"></i> Đăng ký
    </a>
}
</div>

<style>
    .hover-warning:hover {
        color: #ffc107 !important;
        border-color: #ffc107 !important;
    }
    .hover-zoom:hover {
        transform: scale(1.03);
        transition: all 0.2s ease-in-out;
    }
</style>
