@{
    ViewData["Title"] = "Hệ thống Cửa hàng";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">Hệ Thống Cửa Hàng Fatsit Biker</h1>
        <p class="lead text-muted">Với nhiều chi nhánh trên toàn quốc, chúng tôi luôn sẵn sàng phục vụ bạn mọi lúc mọi nơi.</p>
    </div>

    <!-- TPHCM -->
    <h3 class="text-primary mb-3 border-bottom border-secondary pb-2"><i class="fas fa-map-marker-alt me-2"></i>Khu Vực Miền Nam</h3>
    <div class="row g-4 mb-5">
        <!-- Hồ Chí Minh -->
        <div class="col-md-6 col-lg-4">
            <div class="card bg-dark text-white border-secondary h-100 shadow">
                <div class="card-header bg-danger border-secondary fw-bold text-center">
                    TP. Hồ Chí Minh (3 Chi Nhánh)
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush bg-transparent">
                        <li class="list-group-item bg-transparent text-white border-secondary px-0">
                            <strong>Chi nhánh Quận 1:</strong> 123 Lê Lợi, Phường Bến Nghé<br/>
                            <a href="https://maps.google.com/?q=123+Le+Loi+Quan+1+HCM" target="_blank" class="text-info small text-decoration-none"><i class="fas fa-location-arrow"></i> Xem trên Google Map</a>
                        </li>
                        <li class="list-group-item bg-transparent text-white border-secondary px-0">
                            <strong>Chi nhánh Tân Bình:</strong> 456 Cộng Hòa, Phường 13<br/>
                            <a href="https://maps.google.com/?q=456+Cong+Hoa+Tan+Binh+HCM" target="_blank" class="text-info small text-decoration-none"><i class="fas fa-location-arrow"></i> Xem trên Google Map</a>
                        </li>
                        <li class="list-group-item bg-transparent text-white border-secondary px-0">
                            <strong>Chi nhánh Thủ Đức:</strong> 789 Kha Vạn Cân, Linh Trung<br/>
                            <a href="https://maps.google.com/?q=789+Kha+Van+Can+Thu+Duc+HCM" target="_blank" class="text-info small text-decoration-none"><i class="fas fa-location-arrow"></i> Xem trên Google Map</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Cần Thơ -->
        <div class="col-md-6 col-lg-4">
            <div class="card bg-dark text-white border-secondary h-100 shadow">
                <div class="card-header bg-danger border-secondary fw-bold text-center">
                    TP. Cần Thơ (1 Chi Nhánh)
