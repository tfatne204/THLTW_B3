                            <a href="https://maps.google.com/?q=12+Dai+lo+Hoa+Binh+Ninh+Kieu+Can+Tho" target="_blank" class="text-info small text-decoration-none"><i class="fas fa-location-arrow"></i> Xem trên Google Map</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

