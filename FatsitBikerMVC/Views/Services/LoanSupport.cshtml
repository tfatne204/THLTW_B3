@{
    ViewData["Title"] = "Hỗ Trợ Vay Mua Xe";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">Mua Xe Trả Góp Dễ Dàng</h1>
        <p class="lead text-muted">Sở hữu chiếc xe mơ ước ngay hôm nay với các gói vay linh hoạt, thủ tục siêu tốc từ Fatsit Biker.</p>
    </div>

    <div class="row align-items-center g-5 mb-5">
        <div class="col-lg-5 order-lg-2">
            <img src="https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?auto=format&fit=crop&w=800&q=80" alt="Hỗ Trợ Vay Mua Xe" class="img-fluid rounded shadow-lg border border-secondary" />
        </div>
        <div class="col-lg-7 order-lg-1">
            <h2 class="text-primary mb-4">Ưu Điểm Khi Vay Tại Fatsit Biker</h2>
            
            <div class="row g-4 text-white mt-2">
                <div class="col-md-6">
                    <div class="p-4 bg-dark rounded border border-secondary h-100">
                        <i class="fas fa-bolt text-warning fs-1 mb-3"></i>
                        <h5 class="fw-bold">Duyệt Hồ Sơ Nhanh</h5>
                        <p class="text-muted mb-0">Chỉ từ 15-30 phút là có kết quả, nhận xe ngay trong ngày.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4 bg-dark rounded border border-secondary h-100">
                        <i class="fas fa-file-signature text-info fs-1 mb-3"></i>
                        <h5 class="fw-bold">Thủ Tục Đơn Giản</h5>
                        <p class="text-muted mb-0">Chỉ cần CCCD gắn chip hợp lệ. Không cần chứng minh thu nhập với các dòng xe phổ thông.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4 bg-dark rounded border border-secondary h-100">
                        <i class="fas fa-percent text-success fs-1 mb-3"></i>
                        <h5 class="fw-bold">Lãi Suất Cạnh Tranh</h5>
                        <p class="text-muted mb-0">Hợp tác cùng nhiều ngân hàng lớn, mang đến mức lãi suất thấp nhất thị trường.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4 bg-dark rounded border border-secondary h-100">
                        <i class="fas fa-wallet text-danger fs-1 mb-3"></i>
                        <h5 class="fw-bold">Trả Trước Linh Hoạt</h5>
                        <p class="text-muted mb-0">Hỗ trợ trả trước từ 0% đến 50% giá trị xe tùy theo khả năng tài chính của bạn.</p>
                    </div>
                </div>
            </div>

            <button class="btn btn-warning btn-lg mt-5 px-5 fw-bold text-dark" data-bs-toggle="modal" data-bs-target="#interestRateModal"><i class="fas fa-calculator me-2"></i> NHẬN BẢNG TÍNH LÃI SUẤT TẠI ĐÂY</button>
        </div>
    </div>

    <!-- Bảng Lãi Suất Modal -->
    <div class="modal fade" id="interestRateModal" tabindex="-1" aria-labelledby="interestRateModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-dark text-white border-secondary">
          <div class="modal-header border-secondary">
            <h5 class="modal-title text-warning fw-bold" id="interestRateModalLabel">
                <i class="fas fa-percent me-2"></i>Bảng Lãi Suất & Gói Vay Tham Khảo
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4">
            <p class="text-muted mb-4">Fatsit Biker tự hào hợp tác cùng các ngân hàng và tổ chức tài chính uy tín hàng đầu, mang đến cho bạn các gói vay linh hoạt với thủ tục siêu nhanh gọn.</p>
            
            <div class="table-responsive mb-4">
                <table class="table table-dark table-striped table-hover border-secondary align-middle text-center">
                    <thead>
                        <tr class="text-primary">
                            <th class="text-start">Gói Vay / Đối Tác</th>
                            <th>Trả Trước</th>
                            <th>Kỳ Hạn</th>
                            <th>Lãi Suất (Tháng)</th>
                            <th>Thủ Tục</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="text-start fw-bold"><span class="text-danger">FE Credit</span> Sinh Viên</td>
                            <td>Từ 0%</td>
                            <td>6 - 12 tháng</td>
                            <td class="text-warning">0.99%</td>
                            <td>CCCD + Thẻ SV</td>
                        </tr>
                        <tr>
                            <td class="text-start fw-bold"><span class="text-success">Home Credit</span> Phổ Thông</td>
                            <td>Từ 20%</td>
                            <td>6 - 24 tháng</td>
                            <td class="text-warning">1.39%</td>
                            <td>CCCD</td>
                        </tr>
                        <tr>
                            <td class="text-start fw-bold"><span class="text-info">HD Saison</span> Ưu Đãi</td>
                            <td>Từ 30%</td>
                            <td>9 - 24 tháng</td>
                            <td class="text-warning">1.09%</td>
                            <td>CCCD + GPLX/Hộ khẩu</td>
                        </tr>
                        <tr>
                            <td class="text-start fw-bold"><span class="text-warning">Shinhan</span> VIP</td>
                            <td>Từ 50%</td>
                            <td>12 - 36 tháng</td>
                            <td class="text-warning">0.79%</td>
                            <td>Chứng minh thu nhập</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="border border-secondary rounded p-3 text-center h-100">
                        <h6 class="text-info fw-bold mb-2">Vay Qua Thẻ Tín Dụng</h6>
                        <span class="badge bg-danger mb-2">HOT</span>
                        <p class="small text-muted mb-0">Trả góp 0% lãi suất kỳ hạn 3-6-9-12 tháng qua thẻ tín dụng của hơn 25 ngân hàng đối tác.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="border border-secondary rounded p-3 text-center h-100 d-flex flex-column justify-content-center">
                        <h6 class="text-success fw-bold mb-2">Đăng Ký Vay Online</h6>
                        <p class="small text-muted mb-2">Chuyên viên tư vấn sẽ liên hệ ngay trong 5 phút.</p>
                        <a href="tel:18006610" class="btn btn-outline-warning btn-sm rounded-pill mt-auto w-100 fw-bold"><i class="fas fa-phone-alt"></i> Gọi 1800.6610 Ngay</a>
                    </div>
                </div>
            </div>

          </div>
        </div>
      </div>
    </div>
</div>
