@{
    ViewData["Title"] = "Dịch vụ Dán Nano Cho Xe";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">Dán Nano Bảo Vệ Toàn Diện</h1>
        <p class="lead text-muted">Giữ cho chiếc xe của bạn luôn sáng bóng và chống trầy xước với công nghệ Nano tiên tiến nhất.</p>
    </div>

    <div class="row align-items-center g-5 mb-5">
        <div class="col-lg-6">
            <img src="https://images.unsplash.com/photo-1601362840469-51e4d8d58785?auto=format&fit=crop&w=800&q=80" alt="Dán Nano Xe Máy" class="img-fluid rounded shadow-lg border border-secondary" />
        </div>
        <div class="col-lg-6">
            <h2 class="text-primary mb-4">Lợi Ích Của Phủ Nano</h2>
            <ul class="list-unstyled text-white" style="font-size: 1.1rem; line-height: 2;">
                <li><i class="fas fa-check-circle text-success me-2"></i> <strong>Bảo vệ sơn:</strong> Chống ố vàng, phai màu do tia UV.</li>
                <li><i class="fas fa-check-circle text-success me-2"></i> <strong>Chống nước & bụi:</strong> Hiệu ứng lá sen giúp xe ít bám bẩn, dễ vệ sinh.</li>
                <li><i class="fas fa-check-circle text-success me-2"></i> <strong>Độ bóng cao:</strong> Giúp màu sơn sâu và bóng bẩy như mới xuất xưởng.</li>
                <li><i class="fas fa-check-circle text-success me-2"></i> <strong>Chống xước dăm:</strong> Hạn chế các vết xước nhỏ trong quá trình rửa xe hoặc va quẹt nhẹ.</li>
            </ul>
            <div class="mt-4 p-4 bg-dark rounded border border-warning">
                <h4 class="text-warning mb-0">Chỉ từ <strong>800.000 VNĐ</strong> / Gói Tiêu Chuẩn</h4>
                <p class="small text-muted mt-2 mb-0">* Giá có thể thay đổi tùy thuộc vào dòng xe và diện tích bề mặt.</p>
            </div>
            <button class="btn btn-primary btn-lg mt-4 px-5 fw-bold"><i class="fas fa-calendar-alt me-2"></i> ĐẶT LỊCH NGAY</button>
        </div>
    </div>
</div>
