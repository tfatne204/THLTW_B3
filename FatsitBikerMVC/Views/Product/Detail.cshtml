@model FatsitBikerMVC.Models.Product
@{
    ViewData["Title"] = Model.Name;
    long priceValue;
    string formattedPrice = "Liên hệ";
    if(long.TryParse(Model.Price, out priceValue)) {
        formattedPrice = string.Format("{0:N0}", priceValue).Replace(",", ".") + " vnđ";
    } else {
        formattedPrice = Model.Price + " vnđ";
    }
}

@section Styles {
    <style>
        .detail-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 15px; overflow: hidden; }
        .spec-item { border-bottom: 1px solid var(--border-color); padding: 12px 0; display: flex; justify-content: space-between; }
        .spec-label { color: #aaa; font-weight: 500; }
        .spec-value { font-weight: 700; color: #fff; }
        .thumb-img { width: 80px; height: 60px; object-fit: cover; cursor: pointer; border: 2px solid transparent; border-radius: 5px; opacity: 0.6; transition: 0.3s; }
        .thumb-img.active { border-color: var(--primary-color); opacity: 1; }
    </style>
}

<main class="container py-5">
    <div class="mb-4">
        <a asp-action="List" class="btn btn-outline-light btn-sm"><i class="fas fa-arrow-left"></i> QUAY LẠI</a>
    </div>

    <div class="row g-5">
        <div class="col-lg-6">
            <div class="detail-card p-3">
                <img id="main-img" src="@(Model.ProductImages != null && Model.ProductImages.Count > 0 ? Model.ProductImages.FirstOrDefault()?.ImageUrl : "https://via.placeholder.com/800")" class="img-fluid rounded mb-3" alt="@Model.Name" onerror="this.src='https://images.unsplash.com/photo-1558981403-c5f9899a28bc?auto=format&fit=crop&w=800&q=80'">
                
                <div class="mt-3">
                    <p class="small text-muted mb-2 text-uppercase fw-bold">Hình ảnh</p>
                    <div class="d-flex gap-2 overflow-auto pb-2">
                        @if (Model.ProductImages != null)
                        {
                            var imgList = Model.ProductImages.ToList();
                            for (int i = 0; i < imgList.Count; i++)
                            {
                                <img src="@imgList[i].ImageUrl" class="thumb-img @(i == 0 ? "active" : "")" 
                                     onclick="changeImage(this, '@imgList[i].ImageUrl')"
                                     onerror="this.src='https://via.placeholder.com/80x60?text=Error'">
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <span class="badge bg-secondary mb-2">@Model.Category?.Name</span>
            <h1 class="fw-bold mb-2 text-white">@Model.Name</h1>
            <p class="text-muted mb-4">@Model.Desc</p>
            
            <div class="display-4 fw-bold text-primary mb-4">@formattedPrice</div>

            <div class="detail-card p-4 mb-4">
                <h5 class="fw-bold mb-3 text-uppercase" style="color: var(--primary-color)">Thông số kỹ thuật</h5>
                <div class="spec-item">
                    <span class="spec-label"><i class="fas fa-microchip me-2"></i> Động cơ</span>
                    <span class="spec-value">@Model.Engine</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label"><i class="fas fa-bolt me-2"></i> Công suất</span>
                    <span class="spec-value">@Model.Power</span>
                </div>
                <div class="spec-item">
                    <span class="spec-label"><i class="fas fa-weight-hanging me-2"></i> Trọng lượng</span>
                    <span class="spec-value">@Model.Weight</span>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function changeImage(el, imgSrc) {
            document.getElementById('main-img').src = imgSrc;
            document.querySelectorAll('.thumb-img').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }
    </script>
}
