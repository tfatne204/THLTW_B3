@model IEnumerable<FatsitBikerMVC.Models.Product>
@{
    ViewData["Title"] = "Danh sách Sản phẩm";
}

<div class="container py-5">
    <div class="row">
        <!-- Sidebar Danh mục -->
        <div class="col-md-3 mb-4">
            <h4 class="mb-3 text-white">Danh mục</h4>
            <div class="list-group bg-dark rounded border border-secondary">
                <a asp-action="List" asp-route-categoryId="0" asp-route-searchQuery="@ViewBag.SearchQuery" class="list-group-item list-group-item-action bg-dark text-white border-secondary @(ViewBag.CategoryId == 0 && string.IsNullOrEmpty(ViewBag.SearchQuery) ? "active" : "")">Tất cả xe</a>
                @foreach (var cat in ViewBag.Categories)
                {
                    <a asp-action="List" asp-route-categoryId="@cat.Id" asp-route-searchQuery="@ViewBag.SearchQuery" class="list-group-item list-group-item-action bg-dark text-white border-secondary @(ViewBag.CategoryId == cat.Id ? "active" : "")">@cat.Name</a>
                }
            </div>
        </div>

        <!-- Danh sách Sản phẩm -->
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-warning mb-0">@ViewBag.CurrentCategory</h2>
                <form method="get" class="d-flex align-items-center">
                    <input type="hidden" name="categoryId" value="@ViewBag.CategoryId" />
                    @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
                    {
                        <input type="hidden" name="searchQuery" value="@ViewBag.SearchQuery" />
                    }
                    <label class="me-2 text-white text-nowrap">Sắp xếp:</label>
                    <select name="sortOrder" class="form-select bg-dark text-white border-secondary" onchange="this.form.submit()">
                        <option value="" selected="@(string.IsNullOrEmpty(ViewBag.CurrentSort))">Mặc định</option>
                        <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc")">Giá: Thấp đến Cao</option>
                        <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc")">Giá: Cao đến Thấp</option>
                    </select>
                </form>
            </div>
            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var item in Model)
                {
                    <!-- Định dạng giá tiền -->
                    long priceValue;
                    string formattedPrice = "Liên hệ";
                    if(long.TryParse(item.Price, out priceValue)) {
                        formattedPrice = string.Format("{0:N0}", priceValue).Replace(",", ".") + " vnđ";
                    } else {
                        formattedPrice = item.Price + " vnđ";
                    }

                    <div class="col">
                        <div class="card h-100 bg-dark text-white border-secondary">
                            <a asp-action="Detail" asp-route-id="@item.Id">
                                <img src="@(item.ProductImages != null && item.ProductImages.Count > 0 ? item.ProductImages.FirstOrDefault()?.ImageUrl : "https://via.placeholder.com/800")" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1558981403-c5f9899a28bc?auto=format&fit=crop&w=800&q=80'" />
                            </a>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title text-truncate text-white">@item.Name</h5>
                                <p class="text-muted small mb-2">@item.Category?.Name</p>
                                <h4 class="text-primary mt-auto">@formattedPrice</h4>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Phân trang -->
            @if(ViewBag.TotalPages > 1) {
                <nav aria-label="Page navigation" class="mt-5">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link bg-dark text-white border-secondary" asp-action="List" asp-route-categoryId="@ViewBag.CategoryId" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchQuery="@ViewBag.SearchQuery" asp-route-page="@(ViewBag.CurrentPage - 1)">Trang trước</a>
                        </li>
                        
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                <a class="page-link bg-dark text-white border-secondary" asp-action="List" asp-route-categoryId="@ViewBag.CategoryId" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchQuery="@ViewBag.SearchQuery" asp-route-page="@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link bg-dark text-white border-secondary" asp-action="List" asp-route-categoryId="@ViewBag.CategoryId" asp-route-sortOrder="@ViewBag.CurrentSort" asp-route-searchQuery="@ViewBag.SearchQuery" asp-route-page="@(ViewBag.CurrentPage + 1)">Trang sau</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
