@model FatsitBikerMVC.Models.Category

@{
    ViewData["Title"] = "Cập nhật Danh mục";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-white">Cập nhật Danh mục</h2>
                <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
            </div>

            <div class="bg-dark p-4 rounded shadow" style="border: 1px solid var(--border-color);">
                <form asp-action="Update" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label text-warning fw-bold">Tên Danh mục</label>
                        <input asp-for="Name" class="form-control bg-dark text-white border-secondary" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-warning btn-lg fw-bold"><i class="fas fa-edit me-2"></i> Cập Nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
