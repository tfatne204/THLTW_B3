@model IEnumerable<FatsitBikerMVC.Models.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white">Danh sách Danh mục</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm danh mục mới</a>
    </div>

    <div class="table-responsive bg-dark p-3 rounded" style="border: 1px solid var(--border-color);">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 10%">ID</th>
                    <th style="width: 50%">Tên Danh mục</th>
                    <th style="width: 20%">Số lượng Sản phẩm</th>
                    <th style="width: 20%">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-warning fw-bold">#@item.Id</td>
                        <td class="fw-bold fs-5">@item.Name</td>
                        <td>
                            <span class="badge bg-info text-dark">@(item.Products?.Count ?? 0)</span>
                        </td>
                        <td>
                            <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-2"><i class="fas fa-edit"></i> Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Xóa</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">Chưa có danh mục nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
