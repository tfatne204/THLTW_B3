@model IEnumerable<FatsitBikerMVC.Models.ApplicationUser>
@{
    ViewData["Title"] = "Quản lý Người dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-warning fw-bold">
                <i class="fas fa-users me-2"></i> Quản lý Người Dùng
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Create" class="btn btn-success fw-bold shadow-sm hover-zoom">
                <i class="fas fa-plus-circle me-1"></i> Thêm Người Dùng
            </a>
        </div>
    </div>

    <div class="card bg-dark text-white border-secondary shadow-lg rounded-4">
        <div class="card-body p-4">
            <table class="table table-dark table-hover table-bordered border-secondary align-middle text-center mb-0">
                <thead class="table-active">
                    <tr>
                        <th>Họ và tên</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Tuổi</th>
                        <th>Vai trò</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roles = ViewBag.UserRoles[user.Id] as IList<string>;
                        var roleStr = roles != null && roles.Any() ? string.Join(", ", roles) : "Chưa có";
                        <tr>
                            <td class="fw-semibold">@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@(string.IsNullOrEmpty(user.PhoneNumber) ? "Chưa có" : user.PhoneNumber)</td>
                            <td>@user.Age</td>
                            <td>
                                @if (roleStr.Contains("Admin"))
                                {
                                    <span class="badge bg-danger fs-6">@roleStr</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark fs-6">@roleStr</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-warning btn-sm fw-bold hover-zoom mx-1 rounded">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-danger btn-sm fw-bold hover-zoom mx-1 rounded" onclick="return confirm('Bạn có chắc chắn muốn xóa người dùng này?');">
                                            <i class="fas fa-trash-alt"></i> Xóa
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .hover-zoom:hover {
        transform: scale(1.05);
        transition: all 0.2s ease-in-out;
    }
</style>
