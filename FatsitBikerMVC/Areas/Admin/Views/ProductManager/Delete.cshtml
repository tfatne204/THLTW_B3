@model FatsitBikerMVC.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card bg-dark text-white border-danger">
                <div class="card-header border-bottom border-danger bg-danger text-white">
                    <h3 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Xác Nhận Xóa</h3>
                </div>
                <div class="card-body text-center py-4">
                    <h5 class="mb-3">Bạn có chắc chắn muốn xóa sản phẩm này không?</h5>
                    
                    @if (Model.ProductImages != null && Model.ProductImages.Count > 0)
                    {
                        <img src="@Model.ProductImages.FirstOrDefault()?.ImageUrl" alt="@Model.Name" class="img-fluid rounded mb-3 border border-secondary" style="max-height: 200px;" />
                    }
                    
                    <h4 class="text-warning mb-2">@Model.Name</h4>
                    <p class="text-muted mb-4">Mã ID: @Model.Id | Giá: @Model.Price</p>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy Bỏ</a>
                            <button type="submit" class="btn btn-danger px-4"><i class="fas fa-trash"></i> Xác Nhận Xóa</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
