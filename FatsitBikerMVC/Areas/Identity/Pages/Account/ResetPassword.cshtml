@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    var expiryTimeStr = TempData.Peek("TokenExpiry") as string;
    long expiryTimeMs = 0;
    if (!string.IsNullOrEmpty(expiryTimeStr))
    {
        long.TryParse(expiryTimeStr, out expiryTimeMs);
    }
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card bg-dark text-white border-secondary shadow-lg rounded-4">
                <div class="card-header border-bottom border-secondary text-center py-4 bg-black bg-opacity-25 rounded-top-4">
                    <h2 class="fw-bold mb-0 text-warning">🔄 Đặt Lại Mật Khẩu</h2>
                    <p class="text-muted mb-0 mt-2">Hãy nhập Token từ F12 và mật khẩu mới của bạn</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    
                    @if (expiryTimeMs > 0)
                    {
                        <div class="alert alert-warning text-center fw-bold mb-4" id="countdown-alert">
                            ⏳ Mã Token của bạn sẽ hết hạn sau: <span id="countdown-timer" class="text-danger fs-4 mx-2">--</span> giây
                        </div>
                    }

                    <div id="expired-message" class="alert alert-danger text-center fw-bold d-none mb-4">
                        ❌ Mã Token đã hết hạn! Vui lòng yêu cầu lại mã mới.
                        <a asp-page="./ForgotPassword" class="btn btn-outline-danger w-100 mt-3 fw-bold">Yêu cầu lại Mã Token</a>
                    </div>

                    <form method="post" id="reset-password-form">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <!-- Token (Mã xác thực) Input -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code" class="form-control bg-black text-white border-secondary" placeholder="Mã xác thực từ F12" />
                            <label asp-for="Input.Code" class="text-secondary">Mã xác thực (Token) từ F12</label>
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>

                        <!-- Email Input -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control bg-black text-white border-secondary" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-secondary">Email của bạn</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <!-- Password Input -->
                        <div class="input-group mb-3">
                            <div class="form-floating flex-grow-1">
                                <input asp-for="Input.Password" type="password" class="form-control bg-black text-white border-secondary border-end-0 password-input" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu mới" />
                                <label asp-for="Input.Password" class="text-secondary">Mật khẩu mới</label>
                            </div>
                            <span class="input-group-text bg-black border-secondary border-start-0 toggle-password" style="cursor: pointer; color: #ffc107;">
                                <i class="fas fa-eye"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger d-block mb-3" style="margin-top:-10px;"></span>

                        <!-- Confirm Password Input -->
                        <div class="input-group mb-4">
                            <div class="form-floating flex-grow-1">
                                <input asp-for="Input.ConfirmPassword" type="password" class="form-control bg-black text-white border-secondary border-end-0 password-input" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu" />
                                <label asp-for="Input.ConfirmPassword" class="text-secondary">Xác nhận mật khẩu</label>
                            </div>
                            <span class="input-group-text bg-black border-secondary border-start-0 toggle-password" style="cursor: pointer; color: #ffc107;">
                                <i class="fas fa-eye"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger d-block mb-4" style="margin-top:-15px;"></span>

                        <!-- Submit Button -->
                        <button type="submit" id="submit-btn" class="w-100 btn btn-lg btn-warning fw-bold py-3 rounded-3 shadow hover-zoom">
                            ✅ Xác nhận Đổi mật khẩu
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        background-color: #050505 !important;
        border-color: #ffc107 !important;
        color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25) !important;
    }
    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #ffc107 !important;
    }
    .hover-zoom:hover {
        transform: scale(1.02);
        transition: all 0.2s ease-in-out;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            // Password toggle
            $('.toggle-password').click(function () {
                let input = $(this).prev('.form-floating').find('.password-input');
                let icon = $(this).find('i');
                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });

            // Countdown logic
            const expiryTimeMs = @expiryTimeMs;
            if (expiryTimeMs > 0) {
                const timerInterval = setInterval(function () {
                    const now = new Date().getTime();
                    let distance = expiryTimeMs - now;

                    if (distance <= 0) {
                        clearInterval(timerInterval);
                        distance = 0;
                        // Expired
                        $('#countdown-alert').addClass('d-none');
                        $('#reset-password-form').addClass('d-none');
                        $('#expired-message').removeClass('d-none');
                    }
                    
                    const seconds = Math.floor(distance / 1000);
                    $('#countdown-timer').text(seconds);
                    
                }, 1000);
            }
        });
    </script>
}
