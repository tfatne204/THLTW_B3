@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Thành công";
}

<div class="container my-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card bg-dark text-white border-secondary shadow-lg rounded-4 p-5">
                <div class="mb-4 text-success" style="font-size: 4rem;">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h2 class="text-success fw-bold mb-3">Thành Công!</h2>
                <p class="fs-5 mb-4">Mật khẩu của bạn đã được đặt lại thành công.</p>
                <a asp-page="./Login" class="btn btn-warning btn-lg fw-bold shadow hover-zoom">Đăng nhập ngay</a>
            </div>
        </div>
    </div>
</div>
