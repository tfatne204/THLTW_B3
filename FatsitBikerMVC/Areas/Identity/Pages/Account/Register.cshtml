@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card bg-dark text-white border-secondary shadow-lg rounded-4">
                <div class="card-header border-bottom border-secondary text-center py-4 bg-black bg-opacity-25 rounded-top-4">
                    <h2 class="fw-bold mb-0 text-warning">🔑 Đăng Ký</h2>
                    <p class="text-muted mb-0 mt-2">Tạo tài khoản Fatsit Biker mới để trải nghiệm dịch vụ</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <!-- FullName Input -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.FullName" class="form-control bg-black text-white border-secondary" placeholder="Họ và tên" />
                            <label asp-for="Input.FullName" class="text-secondary">Họ và tên</label>
                            <span asp-validation-for="Input.FullName" class="text-danger"></span>
                        </div>

                        <!-- Email Input -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control bg-black text-white border-secondary" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-secondary">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <!-- Address Input -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Address" class="form-control bg-black text-white border-secondary" placeholder="Địa chỉ" />
                            <label asp-for="Input.Address" class="text-secondary">Địa chỉ</label>
                            <span asp-validation-for="Input.Address" class="text-danger"></span>
                        </div>

                        <!-- Age & Phone Number -->
                        <div class="row">
                            <!-- Age Input -->
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.Age" class="form-control bg-black text-white border-secondary" placeholder="Tuổi" />
                                    <label asp-for="Input.Age" class="text-secondary">Tuổi</label>
                                    <span asp-validation-for="Input.Age" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <!-- Phone Number Input -->
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.PhoneNumber" class="form-control bg-black text-white border-secondary" placeholder="Số điện thoại" />
                                    <label asp-for="Input.PhoneNumber" class="text-secondary">Số điện thoại</label>
                                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Password Input -->
                        <div class="input-group mb-3">
                            <div class="form-floating flex-grow-1">
                                <input asp-for="Input.Password" type="password" class="form-control bg-black text-white border-secondary border-end-0 password-input" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu" />
                                <label asp-for="Input.Password" class="text-secondary">Mật khẩu</label>
                            </div>
                            <span class="input-group-text bg-black border-secondary border-start-0 toggle-password" style="cursor: pointer; color: #ffc107;">
                                <i class="fas fa-eye"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger d-block mb-3" style="margin-top:-10px;"></span>

                        <!-- Confirm Password Input -->
                        <div class="input-group mb-4">
                            <div class="form-floating flex-grow-1">
                                <input asp-for="Input.ConfirmPassword" type="password" class="form-control bg-black text-white border-secondary border-end-0 password-input" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu" />
                                <label asp-for="Input.ConfirmPassword" class="text-secondary">Xác nhận mật khẩu</label>
                            </div>
                            <span class="input-group-text bg-black border-secondary border-start-0 toggle-password" style="cursor: pointer; color: #ffc107;">
                                <i class="fas fa-eye"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger d-block mb-4" style="margin-top:-15px;"></span>

                        <!-- Submit Button -->
                        <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-warning fw-bold py-3 rounded-3 shadow hover-zoom">
                            🚀 Đăng Ký
                        </button>
                    </form>
                </div>
                <div class="card-footer border-top border-secondary text-center py-3 bg-black bg-opacity-10 rounded-bottom-4">
                    <span class="text-muted">Đã có tài khoản?</span>
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-warning text-decoration-none fw-bold ms-1">Đăng nhập ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus, .form-select:focus {
        background-color: #050505 !important;
        border-color: #ffc107 !important;
        color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25) !important;
    }
    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label,
    .form-floating > .form-select ~ label {
        color: #ffc107 !important;
    }
    .hover-zoom:hover {
        transform: scale(1.02);
        transition: all 0.2s ease-in-out;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $('.toggle-password').click(function () {
                let input = $(this).prev('.form-floating').find('.password-input');
                let icon = $(this).find('i');
                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('fa-eye').addClass('fa-eye-slash');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('fa-eye-slash').addClass('fa-eye');
                }
            });
        });
    </script>
}
