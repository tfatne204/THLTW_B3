@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu?";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card bg-dark text-white border-secondary shadow-lg rounded-4">
                <div class="card-header border-bottom border-secondary text-center py-4 bg-black bg-opacity-25 rounded-top-4">
                    <h2 class="fw-bold mb-0 text-warning">🔑 Quên Mật Khẩu</h2>
                    <p class="text-muted mb-0 mt-2">Nhập email của bạn để nhận mã xác thực (Token)</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control bg-black text-white border-secondary" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-secondary">Email của bạn</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        
                        <button type="submit" class="w-100 btn btn-lg btn-warning fw-bold py-3 rounded-3 shadow hover-zoom">
                            Lấy mã xác thực
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        background-color: #050505 !important;
        border-color: #ffc107 !important;
        color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25) !important;
    }
    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #ffc107 !important;
    }
    .hover-zoom:hover {
        transform: scale(1.02);
        transition: all 0.2s ease-in-out;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
