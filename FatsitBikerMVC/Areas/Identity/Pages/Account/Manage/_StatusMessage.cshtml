@model string

@if (!String.IsNullOrEmpty(Model))
{
    var statusMessageClass = Model.StartsWith("Error") || Model.StartsWith("Lỗi") ? "danger" : "success";
    <div class="alert alert-@statusMessageClass alert-dismissible shadow-sm fw-bold border-0" role="alert">
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        <i class="fas @(statusMessageClass == "success" ? "fa-check-circle" : "fa-exclamation-triangle") me-2"></i> @Model
    </div>
}
