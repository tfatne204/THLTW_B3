@page
@model IndexModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3 class="mb-4 text-warning"><i class="fas fa-user-edit me-2"></i>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<form id="profile-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="form-floating">
                <input asp-for="Username" class="form-control bg-black text-secondary border-secondary" disabled />
                <label asp-for="Username" class="text-secondary">Tên đăng nhập (Email)</label>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="form-floating">
                <input asp-for="Input.PhoneNumber" class="form-control bg-black text-white border-secondary" placeholder="Nhập số điện thoại" />
                <label asp-for="Input.PhoneNumber" class="text-secondary">Số điện thoại</label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="form-floating">
                <input asp-for="Input.FullName" class="form-control bg-black text-white border-secondary" placeholder="Họ và tên" />
                <label asp-for="Input.FullName" class="text-secondary">Họ và tên</label>
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="form-floating">
                <input asp-for="Input.Age" class="form-control bg-black text-white border-secondary" placeholder="Tuổi" />
                <label asp-for="Input.Age" class="text-secondary">Tuổi</label>
                <span asp-validation-for="Input.Age" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-floating mb-4">
        <input asp-for="Input.Address" class="form-control bg-black text-white border-secondary" placeholder="Địa chỉ" />
        <label asp-for="Input.Address" class="text-secondary">Địa chỉ</label>
        <span asp-validation-for="Input.Address" class="text-danger"></span>
    </div>

    <button id="update-profile-button" type="submit" class="btn btn-warning fw-bold px-5 py-3 shadow hover-zoom">
        <i class="fas fa-save me-2"></i>Lưu thay đổi
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
