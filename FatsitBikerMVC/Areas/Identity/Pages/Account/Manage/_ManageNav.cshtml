@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<ul class="nav nav-pills flex-column gap-2 custom-manage-nav">
    <li class="nav-item">
        <a class="nav-link @ManageNavPages.IndexNavClass(ViewContext) fw-semibold" id="profile" asp-page="./Index">
            <i class="fas fa-user-circle me-2"></i>Hồ sơ cá nhân
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext) fw-semibold" id="change-password" asp-page="./ChangePassword">
            <i class="fas fa-key me-2"></i>Đổi mật khẩu
        </a>
    </li>
</ul>

<style>
    .custom-manage-nav .nav-link {
        color: #adb5bd;
        border-radius: 8px;
        transition: all 0.3s ease;
    }
    .custom-manage-nav .nav-link:hover {
        color: #fff;
        background-color: rgba(255, 255, 255, 0.1);
    }
    .custom-manage-nav .nav-link.active {
        background-color: #ffc107 !important;
        color: #000 !important;
        box-shadow: 0 4px 6px rgba(255, 193, 7, 0.2);
    }
</style>
