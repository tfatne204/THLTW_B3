@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Xác nhận quên mật khẩu";
}

<div class="container my-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card bg-dark text-white border-secondary shadow-lg rounded-4 p-5">
                <h2 class="text-warning fw-bold mb-4">📧 Vui lòng kiểm tra mã xác thực</h2>
                <p class="fs-5">
                    Vì đây là phiên bản giả lập (Bài tập), hệ thống sẽ không gửi Email thực sự.
                </p>
                <div class="alert alert-warning text-dark fw-semibold" role="alert">
                    👉 Hãy nhấn phím <strong>F12</strong> (Mở Developer Tools) -> Chuyển sang tab <strong>Console</strong> để lấy mã <strong>Token</strong>.
                </div>
                <a asp-page="./ResetPassword" class="btn btn-warning mt-3 fw-bold shadow">Chuyển đến trang Đặt lại mật khẩu</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (TempData["ResetToken"] != null)
    {
        <script>
            console.log("%c=========================================", "color: yellow; font-size: 16px; font-weight: bold;");
            console.log("%c🔑 MÃ TOKEN ĐẶT LẠI MẬT KHẨU CỦA BẠN:", "color: #00ff00; font-size: 18px; font-weight: bold;");
            console.log("%c" + "@Html.Raw(TempData["ResetToken"])", "color: #ff0000; font-size: 16px; font-weight: bold; padding: 10px; background: #fff;");
            console.log("%cHãy sao chép mã này và dán vào trường 'Mã xác thực (Token)' ở trang tiếp theo.", "color: yellow; font-size: 14px;");
            console.log("%c=========================================", "color: yellow; font-size: 16px; font-weight: bold;");
        </script>
    }
}
